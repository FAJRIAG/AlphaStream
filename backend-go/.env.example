# AlphaStream Backend — Environment Configuration
# Copy this file to .env and fill in your values

# ─── Application ─────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080

# ─── MySQL (MAMP Mac M1 port = 8889) ────────────────────────
DB_HOST=127.0.0.1
DB_PORT=8889
DB_USER=root
DB_PASSWORD=root
DB_NAME=alphastream
DB_CHARSET=utf8mb4
DB_PARSE_TIME=true
DB_LOC=Local

# ─── Connection Pool (optimized for 8GB RAM / M1) ────────────
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MINUTES=5

# ─── WebSocket ───────────────────────────────────────────────
WS_READ_BUFFER_SIZE=1024
WS_WRITE_BUFFER_SIZE=1024
WS_CLIENT_SEND_BUFFER=256

# ─── Market Simulator ────────────────────────────────────────
SIMULATOR_TICK_INTERVAL_MS=1000
SIMULATOR_ENABLED=true
